  "name": "CRM IA - Ejecutar SQL",
  "active": true,
  "isArchived": false,
  "nodes": [
    {
      "parameters": {
        "workflowInputs": {
          "values": [
            {
              "name": "sql_command"
            },
            {
              "name": "tenant_slug"
            }
          ]
        }
      },
      "id": "trigger-sub",
      "name": "Trigger Sub-workflow",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1.1,
      "position": [
        240,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.sql_command || '';\n\nfunction extraerSQL(input) {\n  let s = input.trim();\n  const mdMatch = s.match(/```(?:sql)?\\s*([\\s\\S]*?)```/i);\n  if (mdMatch) s = mdMatch[1].trim();\n  const selectIdx = s.search(/\\bSELECT\\b/i);\n  if (selectIdx > 0) s = s.slice(selectIdx);\n  s = s.replace(/;\\s*$/, '').trim();\n  return s;\n}\n\nfunction validarSQL(query) {\n  if (!query || query.trim().length === 0) return false;\n  const cleaned = query.trim();\n  // Solo SELECT. Bloquear DDL/DML.\n  const prohibidos = /\\bDROP\\b|\\bTRUNCATE\\b|\\bDELETE\\b|\\bUPDATE\\b|\\bALTER\\b|\\bINSERT\\b|\\bCREATE\\b|\\bGRANT\\b|\\bREVOKE\\b|\\bCOPY\\b|information_schema|pg_catalog/i;\n  if (prohibidos.test(cleaned)) return false;\n  if (!/^SELECT\\b/i.test(cleaned)) return false;\n  return true;\n}\n\nconst sqlLimpio = extraerSQL(raw);\nconst esValida = validarSQL(sqlLimpio);\n\n// Arquitectura 1 DB x cliente: cada credencial PG apunta a la DB del cliente.\n// NO hace falta inyectar tenant_slug: la DB ya está aislada por engine.\nconst sqlFinal = esValida ? sqlLimpio : '';\n\nreturn [{ json: {\n  resultado: esValida ? 'SQL_VALIDO' : 'SQL_INVALIDO',\n  sql_final: sqlFinal,\n  sql_original: raw\n}}];"
      },
      "id": "validate-sql",
      "name": "Validar SQL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        304
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "version": 2,
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "chk1",
              "leftValue": "={{ $json.resultado }}",
              "rightValue": "SQL_VALIDO",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "check-valid",
      "name": "Es valido?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        720,
        304
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "={{ $('Validar SQL').item.json.sql_final }}",
        "options": {}
      },
      "id": "exec-sql",
      "name": "Ejecutar Query",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        960,
        192
      ],
      "credentials": {
        "postgres": {
          "id": "KrrcaHvOt03n78e8",
          "name": "Postgres account 2"
        }
      },
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "errorMessage": "Consulta no permitida. Solo se aceptan SELECT sobre tablas del CRM."
      },
      "id": "stop-error",
      "name": "SQL Rechazado",
      "type": "n8n-nodes-base.stopAndError",
      "typeVersion": 1,
      "position": [
        960,
        432
      ]
    },
    {
      "id": "format-sql-result",
      "name": "Formatear Resultado SQL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1200,
        192
      ],
      "parameters": {
        "jsCode": "const records = $input.all().map(item => item.json);\nconst total = records.length;\n\nif (total === 0) {\n  return [{ json: {\n    resultado: 'Sin registros que coincidan con los criterios. Es probable que no haya datos cargados en la BD para esos filtros.',\n    total: 0,\n    success: true\n  }}];\n}\n\nreturn [{ json: {\n  resultado: JSON.stringify(records, null, 2),\n  total: total,\n  success: true\n}}];"
      }
    }
  ],
